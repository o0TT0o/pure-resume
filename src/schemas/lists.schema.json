{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "列表类型配置 Schema",
  "description": "列表类型配置的验证规则",
  "type": "object",
  "required": ["_meta", "listTypes"],
  "properties": {
    "_meta": {
      "type": "object",
      "required": ["version", "lastModified", "schema", "description"]
    },
    "listTypes": {
      "type": "object",
      "patternProperties": {
        "^[a-z-]+$": {
          "type": "object",
          "required": ["id", "i18nKey", "fields"],
          "properties": {
            "id": { "type": "string" },
            "i18nKey": { "type": "string" },
            "fields": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["id", "i18nKey", "required"],
                "properties": {
                  "id": { "type": "string" },
                  "i18nKey": { "type": "string" },
                  "type": {
                    "type": "string",
                    "enum": ["text", "textarea", "date", "array", "url"]
                  },
                  "required": { "type": "boolean" }
                }
              }
            }
          }
        }
      }
    }
  }
}
